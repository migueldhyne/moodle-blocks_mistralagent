<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="blocks/mistralagent/db" VERSION="20260427.01" COMMENT="XMLDB file for block_mistralagent"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd">
  <TABLES>
    <TABLE NAME="block_mistralagent_agents" COMMENT="Available Mistral agents">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="agent_id" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="description" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="enabled" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="1"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="createdby" TYPE="foreign" FIELDS="createdby" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="agent_id" UNIQUE="true" FIELDS="agent_id"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="block_mistralagent_course" COMMENT="Block instance to agent mapping">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="blockinstanceid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Isolation key — one row per chatbot bloc"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Kept for reporting only"/>
        <FIELD NAME="agentid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="custom_apikey" TYPE="text" NOTNULL="false" COMMENT="Teacher personal API key (encrypted)"/>
        <FIELD NAME="custom_agent_id" TYPE="char" LENGTH="255" NOTNULL="false" COMMENT="Teacher personal Mistral agent ID"/>
        <FIELD NAME="custom_agent_name" TYPE="char" LENGTH="255" NOTNULL="false" COMMENT="Display name of custom agent"/>
        <FIELD NAME="custom_agent_desc" TYPE="text" NOTNULL="false" COMMENT="Description of custom agent"/>
        <FIELD NAME="use_custom_key" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" COMMENT="1=use teacher key, 0=use admin key"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="courseid" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
        <KEY NAME="agentid" TYPE="foreign" FIELDS="agentid" REFTABLE="block_mistralagent_agents" REFFIELDS="id"/>
        <KEY NAME="createdby" TYPE="foreign" FIELDS="createdby" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="blockinstanceid_unique" UNIQUE="true" FIELDS="blockinstanceid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="block_mistralagent_convs" COMMENT="User conversations">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="blockinstanceid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Isolation key"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Kept for reporting"/>
        <FIELD NAME="agentid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="mistral_conversation_id" TYPE="char" LENGTH="255" NOTNULL="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="courseid" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
        <KEY NAME="agentid" TYPE="foreign" FIELDS="agentid" REFTABLE="block_mistralagent_agents" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="userid_blockinstanceid" UNIQUE="false" FIELDS="userid,blockinstanceid"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="block_mistralagent_msgs" COMMENT="Conversation messages">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="conversationid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="role" TYPE="char" LENGTH="20" NOTNULL="true"/>
        <FIELD NAME="content" TYPE="text" NOTNULL="true"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="conversationid" TYPE="foreign" FIELDS="conversationid" REFTABLE="block_mistralagent_convs" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="conversationid_time" UNIQUE="false" FIELDS="conversationid,timecreated"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="block_mistralagent_resources" COMMENT="Block-instance resources for RAG">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="blockinstanceid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Isolation key"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Kept for reporting"/>
        <FIELD NAME="type" TYPE="char" LENGTH="20" NOTNULL="true"/>
        <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true"/>
        <FIELD NAME="source" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="content" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="pending"/>
        <FIELD NAME="error_message" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="filesize" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="createdby" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="courseid" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
        <KEY NAME="createdby" TYPE="foreign" FIELDS="createdby" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="blockinstanceid_status" UNIQUE="false" FIELDS="blockinstanceid,status"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="block_mistralagent_chunks" COMMENT="Text chunks with embeddings for RAG">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="resourceid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="chunk_index" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="chunk_text" TYPE="text" NOTNULL="true"/>
        <FIELD NAME="embedding" TYPE="text" NOTNULL="false"/>
        <FIELD NAME="token_count" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="resourceid" TYPE="foreign" FIELDS="resourceid" REFTABLE="block_mistralagent_resources" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="resourceid_index" UNIQUE="false" FIELDS="resourceid,chunk_index"/>
      </INDEXES>
    </TABLE>

    <TABLE NAME="block_mistralagent_quotas" COMMENT="User message quotas per block instance">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="blockinstanceid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Isolation key"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" COMMENT="Kept for reporting"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="messages_used" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"/>
        <FIELD NAME="messages_limit" TYPE="int" LENGTH="10" NOTNULL="false"/>
        <FIELD NAME="period_start" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="courseid" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="userid_blockinstanceid" UNIQUE="true" FIELDS="userid,blockinstanceid"/>
      </INDEXES>
    </TABLE>
      <TABLE NAME="block_mistralagent_user_keys" COMMENT="Personal Mistral API keys per user">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="apikey" TYPE="text" NOTNULL="true" COMMENT="Encrypted personal Mistral API key"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="userid" TYPE="foreign-unique" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
    </TABLE>
  </TABLES>
</XMLDB>
