    @template block_mistralagent/block

    Block widget displaying the Mistral agent name, a chat button and admin action icons.

    Classes required for JS:
    * none

    Data attributes required for JS:
    * none

    Context variables required for this template:
    * agentname {string} Display name of the Mistral agent.
    * chatpageurl {string} URL to open the chat page.
    * myconversationsurl {string} URL to the user conversation history.
    * canconfig {boolean} Whether the current user can configure the block.
    * configureurl {string} URL to the block configuration page (only when canconfig is true).
    * resourcesurl {string} URL to the resource management page (only when canconfig is true).
    * historyurl {string} URL to the full conversation history page (only when canconfig is true).
    * agentdescription {string} Optional description of the agent (may be empty).

    Example context (json):
    {
        "agentname": "Moodle Assistant",
        "chatpageurl": "/blocks/mistralagent/chat.php?blockinstanceid=1&courseid=2",
        "myconversationsurl": "/blocks/mistralagent/myconversations.php?courseid=2",
        "canconfig": true,
        "configureurl": "/blocks/mistralagent/configure.php?blockinstanceid=1&courseid=2",
        "resourcesurl": "/blocks/mistralagent/resources.php?blockinstanceid=1&courseid=2",
        "historyurl": "/blocks/mistralagent/history.php?courseid=2&blockinstanceid=1",
        "agentdescription": "Ask me anything about this course."
    }
}}
<div class="block-mistralagent-container">

    {{! Row 1: agent avatar and name }}
    <div class="ma-agent-header">
        <div class="agent-avatar">
            <i class="fa fa-robot" aria-hidden="true"></i>
        </div>
        <div class="agent-name">{{agentname}}</div>
    </div>

    {{! Row 2: open chat button (flex 1) + admin icons (fixed size) }}
    <div class="ma-toolbar">

        <a href="{{chatpageurl}}" class="mistralagent-cta-button"
           title="{{#str}}openchat, block_mistralagent{{/str}}">
            <i class="fa fa-comments" aria-hidden="true"></i>
            <span>{{#str}}openchat, block_mistralagent{{/str}}</span>
        </a>

        <div class="ma-admin-icons">
            <a href="{{myconversationsurl}}" class="admin-link"
               title="{{#str}}myconversations, block_mistralagent{{/str}}">
                <i class="fa fa-history" aria-hidden="true"></i>
            </a>
            {{#canconfig}}
            <a href="{{configureurl}}" class="admin-link"
               title="{{#str}}configureagent, block_mistralagent{{/str}}">
                <i class="fa fa-cog" aria-hidden="true"></i>
            </a>
            <a href="{{resourcesurl}}" class="admin-link"
               title="{{#str}}manageresources, block_mistralagent{{/str}}">
                <i class="fa fa-database" aria-hidden="true"></i>
            </a>
            <a href="{{historyurl}}" class="admin-link"
               title="{{#str}}viewhistory, block_mistralagent{{/str}}">
                <i class="fa fa-list-alt" aria-hidden="true"></i>
            </a>
            {{/canconfig}}
        </div>

    </div>

    {{#agentdescription}}
    <div class="agent-description">{{agentdescription}}</div>
    {{/agentdescription}}

</div>
